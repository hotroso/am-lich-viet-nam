<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="Cấu hình Widget"/>
        <LinearLayout
            android:orientation="vertical"
            android:background="@drawable/rounded_background"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="10dp"
            android:paddingEnd="10dp">
            <RelativeLayout
                android:id="@+id/layoutBackgroundColor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="16sp"
                    android:textColor="@color/black"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Màu nền"
                    android:layout_centerVertical="true"
                    android:layout_alignParentStart="true"/>
                <View
                    android:id="@+id/viewBackgroundColor"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_centerVertical="true"
                    android:layout_alignParentEnd="true"/>
            </RelativeLayout>
            <View
                android:background="@android:color/darker_gray"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"/>
            <RelativeLayout
                android:id="@+id/layoutBackgroundSize"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="16sp"
                    android:textColor="@color/black"
                    android:id="@+id/labelBackgroundSize"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chiều cao nền"
                    android:layout_alignParentStart="true"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@android:color/darker_gray"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="(Khuyên dùng để mặc định là 0)"
                    android:layout_below="@+id/labelBackgroundSize"/>
                <EditText
                    android:id="@+id/spinnerBackgroundSize"
                    android:layout_width="50dp"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:hint="0"
                    android:maxLength="3"
                    android:layout_centerVertical="true"
                    android:inputType="number"
                    android:layout_alignParentEnd="true"/>
            </RelativeLayout>
            <View
                android:background="@android:color/darker_gray"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"/>
            <RelativeLayout
                android:id="@+id/layoutTextColor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="16sp"
                    android:textColor="@color/black"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Màu chữ"
                    android:layout_centerVertical="true"
                    android:layout_alignParentStart="true"/>
                <View
                    android:id="@+id/viewTextColor"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_centerVertical="true"
                    android:layout_alignParentEnd="true"/>
            </RelativeLayout>
            <View
                android:background="@android:color/darker_gray"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"/>
            <TextView
                android:textSize="16sp"
                android:textColor="@color/black"
                android:id="@+id/textViewTextSize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cỡ chữ: Mặc định"/>
            <androidx.appcompat.widget.AppCompatSeekBar
                android:id="@+id/seekbar_text_size"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:max="4"
                android:progress="2"/>
            <View
                android:background="@android:color/darker_gray"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"/>
            <TextView
                android:textSize="16sp"
                android:textColor="@color/black"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Xem trước"/>
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="200dp">
                <ImageView
                    android:id="@+id/imageView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/bg_widget_preview"
                    android:scaleType="centerCrop"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/white"
                    android:id="@+id/textView"
                    android:padding="20dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Âm lịch Việt Nam"
                    android:layout_centerInParent="true"/>
            </RelativeLayout>
        </LinearLayout>
        <Button
            android:id="@+id/button_save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Lưu cấu hình"/>
    </LinearLayout>
</ScrollView>
