<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:padding="10dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <TextView
            android:textSize="20sp"
            android:layout_gravity="center"
            android:id="@+id/tv_convert_source"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/solar_calendar"
            android:textAlignment="center"/>

        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:id="@+id/ll_solar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <NumberPicker
                android:id="@+id/np_s_day"
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="20dp"/>

            <NumberPicker
                android:id="@+id/np_s_month"
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="20dp"/>

            <NumberPicker
                android:id="@+id/np_s_year"
                android:layout_width="90dp"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:id="@+id/ll_lunar"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <NumberPicker
                android:id="@+id/np_l_day"
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="20dp"/>

            <NumberPicker
                android:id="@+id/np_l_month"
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="20dp"/>

            <NumberPicker
                android:id="@+id/np_l_year"
                android:layout_width="90dp"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <Button
            android:layout_gravity="center"
            android:id="@+id/btn_switch"
            android:padding="0dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="15dp"
            android:backgroundTint="@android:color/white"
            app:icon="@drawable/ic_switch_vertical"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconTint="@color/colorSecondary"/>

        <TextView
            android:textSize="20sp"
            android:layout_gravity="center"
            android:id="@+id/tv_convert_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/lunar_calendar"
            android:textAlignment="center"/>

        <TextView
            android:textSize="18sp"
            android:layout_gravity="center"
            android:id="@+id/tv_result"
            android:padding="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAlignment="center"/>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
