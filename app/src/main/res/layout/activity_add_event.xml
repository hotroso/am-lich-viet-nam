<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Title -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Tên sự kiện (VD: Giỗ ông nội)">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"/>
        </com.google.android.material.textfield.TextInputLayout>

        <View android:layout_width="match_parent" android:layout_height="12dp"/>

        <!-- Note -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ghi chú (không bắt buộc)">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="2"/>
        </com.google.android.material.textfield.TextInputLayout>

        <View android:layout_width="match_parent" android:layout_height="20dp"/>

        <!-- Lunar date section -->
        <TextView
            android:textStyle="bold"
            android:textSize="16sp"
            android:text="Ngày âm lịch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"/>

        <!-- Row: Ngày / Tháng / Năm -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:hint="Ngày">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etLunarDay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:hint="Tháng">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etLunarMonth"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Năm (tùy chọn)">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etLunarYear"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"/>
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Leap month: auto-detected info or manual checkbox -->
        <LinearLayout
            android:id="@+id/layoutLeapMonth"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp">

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/cbLeapMonth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tháng nhuận"/>

            <TextView
                android:id="@+id/tvLeapInfo"
                android:textSize="12sp"
                android:textColor="@color/vietcal_text_t7_color"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:visibility="gone"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="20dp"/>

        <!-- Event type (mới thêm) -->
        <TextView
            android:textStyle="bold"
            android:textSize="16sp"
            android:text="Loại sự kiện"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupEventType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipGio"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ngày giỗ"
                android:checked="true"/>
            <com.google.android.material.chip.Chip
                android:id="@+id/chipSinhNhat"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sinh nhật"/>
            <com.google.android.material.chip.Chip
                android:id="@+id/chipLe"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ngày lễ"/>
            <com.google.android.material.chip.Chip
                android:id="@+id/chipKhac"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Khác"/>
        </com.google.android.material.chip.ChipGroup>

        <View android:layout_width="match_parent" android:layout_height="20dp"/>

        <!-- Repeat -->
        <TextView
            android:textStyle="bold"
            android:textSize="16sp"
            android:text="Tần suất nhắc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupRepeat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipYearly"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hàng năm"
                android:checked="true"/>
            <com.google.android.material.chip.Chip
                android:id="@+id/chipMonthly"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hàng tháng"/>
            <com.google.android.material.chip.Chip
                android:id="@+id/chipOnce"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Một lần"/>
        </com.google.android.material.chip.ChipGroup>

        <View android:layout_width="match_parent" android:layout_height="20dp"/>

        <!-- Remind days before -->
        <TextView
            android:textStyle="bold"
            android:textSize="16sp"
            android:text="Nhắc trước"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupDaysBefore"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSameDay"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đúng ngày"/>
            <com.google.android.material.chip.Chip
                android:id="@+id/chip1Day"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1 ngày"
                android:checked="true"/>
            <com.google.android.material.chip.Chip
                android:id="@+id/chip2Days"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2 ngày"/>
            <com.google.android.material.chip.Chip
                android:id="@+id/chip7Days"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1 tuần"/>
        </com.google.android.material.chip.ChipGroup>

        <View android:layout_width="match_parent" android:layout_height="20dp"/>

        <!-- Remind time -->
        <TextView
            android:textStyle="bold"
            android:textSize="16sp"
            android:text="Giờ nhắc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPickTime"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="08:00"
            app:strokeColor="@color/colorSecondary"
            android:textColor="@color/colorSecondary"/>

        <View android:layout_width="match_parent" android:layout_height="28dp"/>

        <!-- Buttons row -->
        <LinearLayout
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Hủy"
                android:textAllCaps="false"
                app:strokeColor="@color/colorSecondary"
                android:textColor="@color/colorSecondary"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Lưu"
                android:textAllCaps="false"
                app:backgroundTint="@color/colorSecondary"
                android:textColor="@android:color/white"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
