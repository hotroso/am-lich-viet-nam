<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:contentPadding="12dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Countdown badge (right side) -->
        <TextView
            android:id="@+id/tvCountdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <!-- Title -->
        <TextView
            android:id="@+id/tvUpcomingTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@id/tvCountdown"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:ellipsize="end"
            android:maxLines="1"/>

        <!-- Solar date -->
        <TextView
            android:id="@+id/tvUpcomingDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvUpcomingTitle"
            android:layout_marginTop="4dp"
            android:textSize="14sp"
            android:textColor="@android:color/black"/>

        <!-- Lunar date -->
        <TextView
            android:id="@+id/tvUpcomingLunarDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvUpcomingDate"
            android:layout_marginTop="2dp"
            android:textSize="13sp"
            android:textColor="@android:color/darker_gray"/>

        <!-- Day rating -->
        <TextView
            android:id="@+id/tvUpcomingRating"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvUpcomingLunarDate"
            android:layout_marginTop="4dp"
            android:textSize="12sp"
            android:textStyle="italic"/>

    </RelativeLayout>

</com.google.android.material.card.MaterialCardView>
