<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AmLichVN" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- colorPrimary dùng colorSecondary để mọi widget (input, chip, dialog, button) đều đỏ đậm -->
        <item name="colorPrimary">@color/colorSecondary</item>
        <item name="colorPrimaryVariant">@color/colorSecondary</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorOnSecondary">@android:color/white</item>
        <item name="colorAccent">@color/colorSecondary</item>
        <item name="android:statusBarColor">@color/colorPrimaryDark</item>
        <item name="android:windowBackground">@android:color/white</item>
        <item name="colorControlActivated">@color/colorSecondary</item>
    </style>
</resources>
